# JWT Secret
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# Crawler Configuration
CRAWLER_CONCURRENCY=10
CRAWLER_DELAY_MIN=1000
CRAWLER_DELAY_MAX=3000
