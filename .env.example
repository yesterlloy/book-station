# ============================================
# BookStation 环境变量配置文件
# 复制为 .env 并根据实际情况修改
# ============================================

# ============================================
# 基础配置
# ============================================
# 运行环境: development / test / production
NODE_ENV=production

# 服务端口
HTTP_PORT=80
HTTPS_PORT=443

# 时区
TZ=Asia/Shanghai

# ============================================
# MongoDB 数据库配置
# ============================================
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_USERNAME=admin
MONGO_PASSWORD=your_secure_mongo_password_change_this_in_production
MONGO_DATABASE=bookstation

# ============================================
# Redis 缓存配置
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password_change_this_in_production

# ============================================
# JWT 认证配置
# ============================================
JWT_SECRET=your_super_secure_jwt_secret_key_here_please_change_me_in_production
JWT_EXPIRES_IN=7d

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=info

# ============================================
# 爬虫配置（可选）
# ============================================
CRAWLER_CONCURRENCY=10
CRAWLER_DELAY_MIN=1000
CRAWLER_DELAY_MAX=3000
CRAWLER_TIMEOUT=30
CRAWLER_RETRY_TIMES=3

# ============================================
# 高级配置（通常无需修改
# ============================================
# API 前缀
API_PREFIX=/api

# 后端服务端口（容器内）
BACKEND_PORT=6001

# 管理后台端口
ADMIN_PORT=6003

# Docker Compose 项目名称
COMPOSE_PROJECT_NAME=bookstation

# Docker 构建参数
COMPOSE_DOCKER_CLI_BUILD=1
DOCKER_BUILDKIT=1
